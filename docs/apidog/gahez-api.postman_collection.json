{
  "info": {
    "_postman_id": "gahez-api-v1",
    "name": "Gahez API v1",
    "description": "Customer REST API. Import into Apidog via Postman Collection.\n\nDemo: customer1@gmail.com / 12345678",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://gahez.test/api/v1" },
    { "key": "token", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "addressId", "value": "1" },
    { "key": "cartItemId", "value": "1" },
    { "key": "ticketId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  pm.test('Token saved', () => pm.expect(json.data.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "en" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"customer1@gmail.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"12345678\",\n  \"password_confirmation\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{baseUrl}}/auth/logout" }
        },
        {
          "name": "Current user",
          "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{baseUrl}}/auth/user" }
        }
      ]
    },
    {
      "name": "Store",
      "item": [
        {
          "name": "Store config",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/store/config"
          }
        }
      ]
    },
    {
      "name": "Catalog (public)",
      "item": [
        { "name": "Categories", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/categories" } },
        { "name": "Categories tree", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/categories/tree" } },
        { "name": "Products", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/products?per_page=15" } },
        { "name": "Product by ID", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/products/{{productId}}" } },
        { "name": "Brands", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/brands" } },
        { "name": "Branches", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/branches" } },
        { "name": "Sliders", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/sliders" } },
        { "name": "Offers", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/offers" } }
      ]
    },
    {
      "name": "Profile",
      "item": [
        { "name": "Get profile", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{baseUrl}}/profile" } },
        {
          "name": "Update profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Customer1\",\n  \"birthdate\": \"1992-05-20\"\n}" },
            "url": "{{baseUrl}}/profile"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "List notifications", "request": { "method": "GET", "url": "{{baseUrl}}/notifications?per_page=20" } },
        { "name": "Mark all read", "request": { "method": "POST", "url": "{{baseUrl}}/notifications/mark-all-read" } }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        { "name": "List addresses", "request": { "method": "GET", "url": "{{baseUrl}}/addresses" } },
        {
          "name": "Create address",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Home\",\n  \"address\": \"Block 5, Street 12, Salmiya\",\n  \"latitude\": \"29.3375\",\n  \"longitude\": \"48.0758\",\n  \"phone\": \"50001111\",\n  \"city\": \"Salmiya\",\n  \"state\": \"Hawalli\",\n  \"is_default\": true\n}"
            },
            "url": "{{baseUrl}}/addresses"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        { "name": "Get cart", "request": { "method": "GET", "url": "{{baseUrl}}/cart" } },
        { "name": "Checkout preview", "request": { "method": "GET", "url": "{{baseUrl}}/cart/checkout-preview" } },
        {
          "name": "Add to cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 1\n}" },
            "url": "{{baseUrl}}/cart/{{productId}}"
          }
        },
        {
          "name": "Update cart quantity (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 7\n}" },
            "url": "{{baseUrl}}/cart/{{productId}}"
          }
        },
        {
          "name": "Update cart item by id (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 7\n}" },
            "url": "{{baseUrl}}/cart/items/{{cartItemId}}"
          }
        },
        {
          "name": "Apply coupon",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"WELCOME10\"\n}" },
            "url": "{{baseUrl}}/cart/apply-coupon"
          }
        },
        { "name": "Clear cart", "request": { "method": "DELETE", "url": "{{baseUrl}}/cart" } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        { "name": "List orders", "request": { "method": "GET", "url": "{{baseUrl}}/orders" } },
        {
          "name": "Checkout (create order)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address_id\": {{addressId}},\n  \"payment_method\": \"cash_on_delivery\",\n  \"use_wallet\": false,\n  \"notes\": \"Leave at door\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        { "name": "Show order", "request": { "method": "GET", "url": "{{baseUrl}}/orders/{{orderId}}" } },
        { "name": "Cancel order", "request": { "method": "POST", "url": "{{baseUrl}}/orders/{{orderId}}/cancel" } },
        { "name": "Pay order (wallet)", "request": {
          "method": "POST",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": { "mode": "raw", "raw": "{\n  \"payment_method\": \"wallet\"\n}" },
          "url": "{{baseUrl}}/orders/{{orderId}}/pay"
        } },
        { "name": "Rate order", "request": {
          "method": "POST",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great service\"\n}" },
          "url": "{{baseUrl}}/orders/{{orderId}}/rate"
        } },
        { "name": "Refund requests", "request": { "method": "GET", "url": "{{baseUrl}}/refund-requests" } }
      ]
    },
    {
      "name": "Wishlist & Wallet",
      "item": [
        { "name": "Wishlist", "request": { "method": "GET", "url": "{{baseUrl}}/wishlist" } },
        { "name": "Toggle wishlist", "request": { "method": "POST", "url": "{{baseUrl}}/wishlist/{{productId}}" } },
        { "name": "Wallet history", "request": { "method": "GET", "url": "{{baseUrl}}/wallet/history" } }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        { "name": "List tickets", "request": { "method": "GET", "url": "{{baseUrl}}/tickets" } },
        {
          "name": "Create ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"subject\": \"Order issue\",\n  \"description\": \"My order was delayed.\"\n}" },
            "url": "{{baseUrl}}/tickets"
          }
        },
        {
          "name": "Create ticket with attachment",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "subject", "value": "Order issue", "type": "text" },
                { "key": "description", "value": "Please see attached photo.", "type": "text" },
                { "key": "attachments[0]", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/tickets"
          }
        },
        {
          "name": "Add ticket message",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "message", "value": "Here is more detail.", "type": "text" },
                { "key": "attachments[0]", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}/messages"
          }
        }
      ]
    }
  ]
}
